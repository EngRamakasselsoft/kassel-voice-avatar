# --- Benchmark ---
BENCHMARK_ENABLED=true
BENCHMARK_LOG_DIR=./logs
LIVEKIT_AGENT_NAME=kassel-examiner

# --- Optional ---
GOOGLE_API_KEY=your_google_api_key_here
TAVUS_API_KEY=your_tavus_api_key_here
